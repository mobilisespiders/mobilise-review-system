DATABASE_URL=mysql+mysqlconnector://USER:PASSWORD@HOST:PORT/DATABASE
# Optional for Aiven MySQL when SSL CA verification is enabled.
# On Render, upload the CA as a secret file and set this to that file path.
DATABASE_SSL_CA_PATH=

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

ALLOWED_ORIGINS=http://localhost:3000,https://mti-review.vercel.app,https://your-vercel-preview-url.vercel.app
